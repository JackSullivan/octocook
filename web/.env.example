# Copy to .env.local (which is gitignored) and set the LAN IP of the laptop
# running the FastAPI backend. Only needed when building the Capacitor
# Android app — the phone can't reach 127.0.0.1.
#
# Find your laptop IP with: ipconfig getifaddr en0  (Wi-Fi)
#                       or: ipconfig getifaddr en1
VITE_API_BASE_URL=http://192.168.0.196:8000
